# ==========================================================
# VYP FPV — Variables d'environnement
# Copie ce fichier en ".env.local" en local, et renseigne les
# memes valeurs dans Vercel > Project > Settings > Environment
# Variables (jamais dans le code, jamais commit sur GitHub).
# ==========================================================

# --- Supabase ---
# Dashboard Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxx
# Cle "service_role" -> SECRETE, jamais exposee au client.
# Utilisee uniquement dans les routes serveur (admin, webhook).
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxx

# --- Stripe ---
# Dashboard Stripe > Developers > API keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx
# Dashboard Stripe > Developers > Webhooks > ta route
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://vyp-fpv.vercel.app
